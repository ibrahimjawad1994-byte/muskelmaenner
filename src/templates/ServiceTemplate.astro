---
import Layout from "../layouts/Layout.astro";
import { company } from "../config/company";

import {
  Clock3,
  BadgeEuro,
  BrushCleaning,
} from "lucide-astro";

const {
  metaTitle,
  badge,
  headline,
  intro,
  whatsappText,
  benefits,
  contentTitle,
  contentParagraphs,
  steps,
  areaTitle,
  areaParagraphs,
  faqs,
  ctaTitle,
  ctaText,
} = Astro.props;

const waHref = `https://wa.me/${company.whatsappNumber}?text=${encodeURIComponent(
  whatsappText
)}`;
---

<Layout title={metaTitle}>
  <section class="relative overflow-hidden py-16 sm:py-24">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-zinc-50 to-white"></div>
      <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-zinc-100 blur-3xl"></div>
    </div>

    <div class="max-w-3xl">
      <p class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-4 py-1.5 text-sm text-zinc-600 shadow-sm">
        <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
        {badge}
      </p>

      <h1 class="mt-8 text-5xl font-semibold tracking-tight text-zinc-900 sm:text-6xl">
        {headline}
      </h1>

      <p class="mt-6 text-lg leading-8 text-zinc-600">
        {intro}
      </p>

      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl bg-zinc-900 px-7 py-4 text-sm font-medium text-white transition hover:bg-zinc-800"
        >
          WhatsApp Anfrage
        </a>

        <a
          href="/kontakt"
          class="rounded-2xl border border-zinc-300 bg-white px-7 py-4 text-sm font-medium text-zinc-900 transition hover:bg-zinc-50"
        >
          Kostenloses Angebot
        </a>
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="grid gap-6 md:grid-cols-3">
      {
        benefits.map((benefit, index) => (
          <div class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-900 text-white">
              {
                index === 0 ? (
                  <Clock3 size={22} />
                ) : index === 1 ? (
                  <BadgeEuro size={22} />
                ) : (
                  <BrushCleaning size={22} />
                )
              }
            </div>

            <h2 class="text-lg font-semibold tracking-tight">
              {benefit.title}
            </h2>

            <p class="mt-3 text-sm leading-7 text-zinc-600">
              {benefit.text}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="pb-20">
    <div class="max-w-3xl">
      <h2 class="text-4xl font-semibold tracking-tight">
        {contentTitle}
      </h2>

      <div class="mt-6 space-y-5 leading-8 text-zinc-600">
        {contentParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="rounded-[2rem] border border-zinc-200 bg-zinc-50 p-8 sm:p-10">
      <div class="mb-10">
        <p class="text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
          Ablauf
        </p>

        <h2 class="mt-4 text-4xl font-semibold tracking-tight">
          So läuft es ab
        </h2>
      </div>

      <div class="grid gap-6 md:grid-cols-3">
        {
          steps.map((step, index) => (
            <div class="rounded-2xl border border-zinc-200 bg-white p-6">
              <p class="text-sm text-zinc-500">
                Schritt {index + 1}
              </p>

              <h3 class="mt-3 font-semibold">
                {step.title}
              </h3>

              <p class="mt-3 text-sm leading-7 text-zinc-600">
                {step.text}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="rounded-[2rem] border border-zinc-200 bg-white p-8 shadow-sm sm:p-10">
      <h2 class="text-4xl font-semibold tracking-tight">
        {areaTitle}
      </h2>

      <div class="mt-6 space-y-5 leading-8 text-zinc-600">
        {areaParagraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </section>

  <section class="pb-20">
    <div class="mb-10">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
        FAQ
      </p>

      <h2 class="mt-4 text-4xl font-semibold tracking-tight">
        Häufige Fragen
      </h2>
    </div>

    <div class="space-y-4">
      {
        faqs.map((faq) => (
          <div class="rounded-2xl border border-zinc-200 bg-white p-6 shadow-sm">
            <h3 class="font-semibold">
              {faq.question}
            </h3>

            <p class="mt-3 leading-7 text-zinc-600">
              {faq.answer}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="pb-24">
    <div class="rounded-[2rem] bg-zinc-900 p-8 text-white sm:p-10">
      <h2 class="text-4xl font-semibold tracking-tight">
        {ctaTitle}
      </h2>

      <p class="mt-5 max-w-2xl leading-8 text-zinc-300">
        {ctaText}
      </p>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-2xl bg-white px-7 py-4 text-sm font-medium text-zinc-900 transition hover:bg-zinc-100"
        >
          WhatsApp öffnen
        </a>

        <a
          href="/kontakt"
          class="rounded-2xl border border-white/20 px-7 py-4 text-sm font-medium text-white transition hover:bg-white/10"
        >
          Kontaktformular
        </a>
      </div>
    </div>
  </section>
</Layout>