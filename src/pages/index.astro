---
import Layout from "../layouts/Layout.astro";

import {
  Clock3,
  BadgeEuro,
  BrushCleaning,
  ShieldCheck,
  MapPinned,
} from "lucide-astro";

const serviceArea = "Berlin & Brandenburg";
const phoneDisplay = "+49 162 4626510";
const phoneTel = "+491624626510";
const whatsappNumber = "491624626510";

const whatsappPrefill =
  "Hallo Muskelmänner! Ich möchte eine Entrümpelung anfragen. Ort/PLZ: __, Objekt: __, Wunschtermin: __.";

const waHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(
  whatsappPrefill
)}`;
---

<Layout title="Muskelmänner | Entrümpelung Berlin">
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-zinc-50 to-white"></div>
      <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-zinc-100 blur-3xl"></div>
      <div class="absolute bottom-0 left-0 h-72 w-72 rounded-full bg-zinc-100 blur-3xl"></div>
    </div>

    <div class="grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div>
        <p class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-4 py-1.5 text-sm text-zinc-600 shadow-sm">
          <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
          {serviceArea}
        </p>

        <h1 class="font-heading mt-8 max-w-3xl text-5xl font-semibold leading-none tracking-tight text-zinc-950 sm:text-6xl lg:text-7xl">
          Entrümpelung mit Struktur, Kraft und Zuverlässigkeit.
        </h1>

        <p class="mt-8 max-w-2xl text-lg leading-8 text-zinc-600">
          Muskelmänner übernimmt Wohnungsentrümpelungen,
          Haushaltsauflösungen, Keller- und Büroentrümpelungen in Berlin und
          Brandenburg. Schnell, sauber und auf Wunsch besenrein.
        </p>

        <div class="mt-10 flex flex-wrap gap-4">
          <a
            href={waHref}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-2xl bg-zinc-950 px-7 py-4 text-sm font-medium text-white transition hover:bg-black"
          >
            WhatsApp Anfrage
          </a>

          <a
            href="/kontakt"
            class="rounded-2xl border border-zinc-300 bg-white px-7 py-4 text-sm font-medium text-zinc-900 transition hover:bg-zinc-50"
          >
            Kostenloses Angebot
          </a>

          <a
            href={`tel:${phoneTel}`}
            class="rounded-2xl border border-zinc-300 bg-white px-7 py-4 text-sm font-medium text-zinc-900 transition hover:bg-zinc-50"
          >
            {phoneDisplay}
          </a>
        </div>

        <div class="mt-10 flex flex-wrap gap-6 text-sm text-zinc-600">
          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
            Festpreis möglich
          </div>

          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
            Kurzfristige Termine
          </div>

          <div class="flex items-center gap-2">
            <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
            Besenrein auf Wunsch
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute -right-6 -top-6 h-40 w-40 rounded-full bg-zinc-200 blur-3xl"></div>

        <div class="relative overflow-hidden rounded-[2.5rem] bg-zinc-950 p-6 text-white shadow-2xl sm:p-8 lg:p-10">
          <div class="absolute inset-0 opacity-10">
            <div class="absolute left-0 top-0 h-full w-full bg-[radial-gradient(circle_at_top_left,white,transparent_35%)]"></div>
          </div>

          <div class="relative">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.22em] text-zinc-400">
                  Muskelmänner
                </p>

                <h2 class="font-heading mt-3 text-3xl font-semibold tracking-tight sm:text-4xl">
                  Entrümpelung mit System
                </h2>
              </div>

              <div class="w-fit rounded-2xl border border-white/10 bg-white/10 px-4 py-2 text-sm">
                Berlin
              </div>
            </div>

            <div class="mt-10 grid gap-4">
              <div class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur sm:p-6">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm text-zinc-400">Wohnungsentrümpelung</p>
                    <p class="mt-2 text-xl font-semibold">Schnell & zuverlässig</p>
                  </div>

                  <div class="h-3 w-3 shrink-0 rounded-full bg-emerald-400"></div>
                </div>
              </div>

              <div class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur sm:p-6">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm text-zinc-400">Haushaltsauflösung</p>
                    <p class="mt-2 text-xl font-semibold">Diskret & strukturiert</p>
                  </div>

                  <div class="h-3 w-3 shrink-0 rounded-full bg-emerald-400"></div>
                </div>
              </div>

              <div class="rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur sm:p-6">
                <div class="flex items-center justify-between gap-4">
                  <div>
                    <p class="text-sm text-zinc-400">Keller & Büro</p>
                    <p class="mt-2 text-xl font-semibold">Flexibel planbar</p>
                  </div>

                  <div class="h-3 w-3 shrink-0 rounded-full bg-emerald-400"></div>
                </div>
              </div>
            </div>

            <div class="mt-8 grid gap-4 sm:grid-cols-3">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center sm:p-5">
                <p class="text-2xl font-semibold sm:text-3xl">350 km</p>
                <p class="mx-auto mt-2 max-w-[8rem] text-[10px] uppercase leading-5 tracking-[0.14em] text-zinc-400">
                  auf Anfrage
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center sm:p-5">
                <p class="text-2xl font-semibold sm:text-3xl">24 h</p>
                <p class="mx-auto mt-2 max-w-[8rem] text-[10px] uppercase leading-5 tracking-[0.14em] text-zinc-400">
                  schnelle Antwort
                </p>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/5 p-4 text-center sm:p-5">
                <p class="text-2xl font-semibold sm:text-3xl">Fair</p>
                <p class="mx-auto mt-2 max-w-[8rem] text-[10px] uppercase leading-5 tracking-[0.14em] text-zinc-400">
                  transparente Preise
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="rounded-[2.5rem] border border-zinc-200 bg-white p-8 shadow-sm sm:p-10">
      <div class="grid gap-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
            Einsatzgebiet
          </p>

          <h2 class="font-heading mt-4 text-5xl font-semibold leading-none tracking-tight text-zinc-950">
            Berlin, Brandenburg und Umgebung.
          </h2>

          <p class="mt-6 leading-8 text-zinc-600">
            Unser Schwerpunkt liegt in Berlin und Brandenburg. Je nach Objekt,
            Umfang und Planung übernehmen wir Einsätze auch im weiteren Umkreis
            bis etwa 350 km.
          </p>
        </div>

        <div class="rounded-[2rem] bg-zinc-950 p-6 text-white">
          <div class="flex items-start gap-5">
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white text-zinc-950">
              <MapPinned size={22} />
            </div>

            <div>
              <h3 class="text-2xl font-semibold">
                Von Berlin aus im Einsatz
              </h3>

              <p class="mt-4 leading-8 text-zinc-300">
                Wohnungsentrümpelung, Haushaltsauflösung, Kellerentrümpelung
                und Büroentrümpelung in Berlin, Brandenburg und umliegenden
                Regionen.
              </p>

              <div class="mt-6 grid gap-3 sm:grid-cols-3">
                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-sm text-zinc-400">Schwerpunkt</p>
                  <p class="mt-1 font-medium">Berlin</p>
                </div>

                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-sm text-zinc-400">Region</p>
                  <p class="mt-1 font-medium">Brandenburg</p>
                </div>

                <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                  <p class="text-sm text-zinc-400">Umkreis</p>
                  <p class="mt-1 font-medium">bis 350 km</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-24">
    <div class="mb-12">
      <p class="text-sm font-medium uppercase tracking-[0.2em] text-zinc-500">
        Vorteile
      </p>

      <h2 class="font-heading mt-4 text-5xl font-semibold tracking-tight">
        Warum Muskelmänner?
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      <div class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-900 text-white">
          <Clock3 size={22} />
        </div>

        <h3 class="text-lg font-semibold">Kurzfristige Termine</h3>

        <p class="mt-3 text-sm leading-7 text-zinc-600">
          Flexible Planung und schnelle Durchführung in Berlin und Umgebung.
        </p>
      </div>

      <div class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-900 text-white">
          <BadgeEuro size={22} />
        </div>

        <h3 class="text-lg font-semibold">Faire Festpreise</h3>

        <p class="mt-3 text-sm leading-7 text-zinc-600">
          Transparente Angebote ohne versteckte Kosten.
        </p>
      </div>

      <div class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-900 text-white">
          <BrushCleaning size={22} />
        </div>

        <h3 class="text-lg font-semibold">Besenrein möglich</h3>

        <p class="mt-3 text-sm leading-7 text-zinc-600">
          Auf Wunsch hinterlassen wir die Räume ordentlich und sauber.
        </p>
      </div>

      <div class="rounded-3xl border border-zinc-200 bg-white p-7 shadow-sm">
        <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-2xl bg-zinc-900 text-white">
          <ShieldCheck size={22} />
        </div>

        <h3 class="text-lg font-semibold">Diskret & zuverlässig</h3>

        <p class="mt-3 text-sm leading-7 text-zinc-600">
          Professionelle Abwicklung mit klarer Kommunikation.
        </p>
      </div>
    </div>
  </section>
</Layout>