---
import Layout from "../layouts/Layout.astro";
import { company } from "../config/company";

const whatsappPrefill =
  "Hallo Muskelmänner! Ich habe gerade eine Anfrage über die Website gesendet und möchte jetzt Fotos vom Objekt schicken.";

const waHref = `https://wa.me/${company.whatsappNumber}?text=${encodeURIComponent(
  whatsappPrefill
)}`;
---

<Layout title={`Vielen Dank – ${company.name}`}>
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-b from-zinc-50 to-white"></div>

      <div class="absolute right-0 top-0 h-72 w-72 rounded-full bg-zinc-100 blur-3xl"></div>

      <div class="absolute bottom-0 left-0 h-72 w-72 rounded-full bg-zinc-100 blur-3xl"></div>
    </div>

    <div class="mx-auto max-w-4xl text-center">
      <p class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-4 py-1.5 text-sm text-zinc-600 shadow-sm">
        <span class="h-2 w-2 rounded-full bg-zinc-900"></span>
        Anfrage erfolgreich gesendet
      </p>

      <h1 class="font-heading mt-8 text-5xl font-semibold tracking-tight text-zinc-950 sm:text-6xl">
        Vielen Dank für Ihre Anfrage.
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-8 text-zinc-600">
        Ihre Anfrage wurde erfolgreich übermittelt. Wir melden uns schnellstmöglich
        bei Ihnen zurück.
      </p>

      <!-- WhatsApp CTA -->

      <div class="mt-12 rounded-[2.5rem] bg-zinc-950 p-8 text-white shadow-2xl sm:p-10">
        <p class="text-sm uppercase tracking-[0.22em] text-zinc-400">
          Fotos senden
        </p>

        <h2 class="font-heading mt-4 text-4xl font-semibold leading-none">
          Haben Sie Bilder vom Objekt?
        </h2>

        <p class="mx-auto mt-5 max-w-2xl leading-8 text-zinc-300">
          Senden Sie uns jetzt Fotos per WhatsApp. Das hilft uns dabei,
          Aufwand und Preis schneller und genauer einzuschätzen.
        </p>

        <a
          href={waHref}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex rounded-2xl bg-white px-8 py-4 text-sm font-medium text-zinc-950 transition hover:bg-zinc-100"
        >
          Fotos per WhatsApp senden
        </a>
      </div>

      <!-- Info Cards -->

      <div class="mt-12 grid gap-4 text-left sm:grid-cols-3">
        <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="font-semibold text-zinc-950">
            Schnelle Rückmeldung
          </h2>

          <p class="mt-3 text-sm leading-6 text-zinc-600">
            Wir prüfen Ihre Anfrage schnellstmöglich und melden uns zeitnah.
          </p>
        </div>

        <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="font-semibold text-zinc-950">
            Fotos per WhatsApp
          </h2>

          <p class="mt-3 text-sm leading-6 text-zinc-600">
            Bilder helfen uns bei einer besseren Einschätzung des Aufwands.
          </p>
        </div>

        <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm">
          <h2 class="font-semibold text-zinc-950">
            Berlin & Brandenburg
          </h2>

          <p class="mt-3 text-sm leading-6 text-zinc-600">
            Wir sind in Berlin, Brandenburg und Umgebung im Einsatz.
          </p>
        </div>
      </div>

      <!-- Buttons -->

      <div class="mt-12 flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="rounded-2xl bg-zinc-950 px-7 py-4 text-sm font-medium text-white transition hover:bg-zinc-800"
        >
          Zur Startseite
        </a>

        <a
          href="/kontakt"
          class="rounded-2xl border border-zinc-300 bg-white px-7 py-4 text-sm font-medium text-zinc-900 transition hover:bg-zinc-50"
        >
          Neue Anfrage
        </a>
      </div>
    </div>
  </section>
</Layout>