---
import MobileMenu from "./MobileMenu.jsx";
import Logo from "./Logo.astro";
---

<header class="sticky top-0 z-50 w-full overflow-x-clip border-b border-zinc-200/80 bg-white/95 backdrop-blur-xl">
  <div class="mx-auto flex h-[92px] max-w-7xl items-center justify-between gap-3 px-4 sm:px-6 lg:h-auto lg:px-8 lg:py-5">
    <div class="min-w-0 flex-1 overflow-hidden">
      <Logo />
    </div>

    <div class="shrink-0 lg:hidden">
      <MobileMenu client:load />
    </div>

    <nav class="hidden items-center gap-10 lg:flex">
      <a href="/" class="text-sm font-medium tracking-[0.08em] text-zinc-600 hover:text-zinc-950">Start</a>
      <a href="/leistungen" class="text-sm font-medium tracking-[0.08em] text-zinc-600 hover:text-zinc-950">Leistungen</a>
      <a href="/preise" class="text-sm font-medium tracking-[0.08em] text-zinc-600 hover:text-zinc-950">Preise</a>
      <a href="/kontakt" class="text-sm font-medium tracking-[0.08em] text-zinc-600 hover:text-zinc-950">Kontakt</a>
    </nav>

    <a
      href="/kontakt"
      class="hidden rounded-2xl bg-zinc-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-zinc-800 lg:block"
    >
      Angebot anfragen
    </a>
  </div>
</header>