---
import { company } from "../config/company";

const whatsappPrefill =
  "Hallo Muskelmänner! Ich möchte eine Entrümpelung anfragen.";

const waHref = `https://wa.me/${company.whatsappNumber}?text=${encodeURIComponent(
  whatsappPrefill
)}`;
---

<a
  href={waHref}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="WhatsApp Anfrage"
  data-analytics-event="whatsapp_click"
  data-analytics-label="Floating WhatsApp Button"
  class="group fixed bottom-5 right-5 z-50 flex items-center gap-3 rounded-full bg-zinc-950 px-5 py-3.5 text-white shadow-2xl transition duration-300 hover:scale-[1.03] hover:bg-black"
>
  <!-- Glow -->
  <span class="absolute inset-0 rounded-full bg-zinc-950 opacity-20 blur-xl"></span>

  <!-- WhatsApp Icon -->
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 32 32"
    class="relative h-5 w-5 fill-current"
  >
    <path
      d="M19.11 17.38c-.27-.14-1.58-.78-1.82-.87-.24-.09-.42-.14-.6.14-.18.27-.69.87-.85 1.05-.16.18-.31.2-.58.07-.27-.14-1.12-.41-2.13-1.31-.79-.7-1.32-1.56-1.47-1.82-.16-.27-.02-.41.12-.55.13-.13.27-.31.4-.47.13-.16.18-.27.27-.45.09-.18.04-.34-.02-.47-.07-.14-.6-1.45-.82-1.98-.22-.53-.45-.45-.6-.46h-.51c-.18 0-.47.07-.72.34-.25.27-.95.93-.95 2.27 0 1.34.97 2.63 1.11 2.81.13.18 1.9 2.9 4.6 4.07.64.27 1.14.43 1.53.55.64.2 1.22.17 1.68.1.51-.08 1.58-.65 1.8-1.28.22-.63.22-1.17.16-1.28-.07-.11-.25-.18-.52-.31zM16.01 3C8.83 3 3 8.82 3 16c0 2.54.74 4.99 2.13 7.09L3.5 28.5l5.56-1.6A12.95 12.95 0 0016.01 29C23.18 29 29 23.18 29 16S23.18 3 16.01 3zm0 23.67c-2.09 0-4.14-.56-5.93-1.63l-.42-.25-3.3.95.88-3.22-.27-.44A10.63 10.63 0 015.33 16c0-5.88 4.79-10.67 10.68-10.67 2.85 0 5.53 1.11 7.54 3.13A10.6 10.6 0 0126.68 16c0 5.88-4.79 10.67-10.67 10.67z"
    />
  </svg>

  <!-- Text -->
  <div class="relative hidden sm:block">
    <p class="text-[10px] uppercase tracking-[0.22em] text-zinc-500">
      WhatsApp
    </p>

    <p class="text-[15px] font-medium tracking-tight">
      Schnell anfragen
    </p>
  </div>
</a>

<script is:inline>
  document.addEventListener("click", (event) => {
    const link = event.target.closest("[data-analytics-event='whatsapp_click']");

    if (!link || typeof window.gtag !== "function") {
      return;
    }

    window.gtag("event", "whatsapp_click", {
      event_category: "Kontakt",
      event_label: link.dataset.analyticsLabel || "WhatsApp Button",
      link_url: link.href,
    });
  });
</script>