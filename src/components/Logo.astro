---
const { variant = "default" } = Astro.props;

const isLight = variant === "light";
---

<a href="/" class="group flex min-w-0 items-center gap-3 sm:gap-5">
  <div
    class={`relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-2xl transition duration-300 group-hover:scale-[1.02] sm:h-16 sm:w-16 sm:rounded-[1.6rem] ${
      isLight
        ? "bg-white text-zinc-950"
        : "bg-zinc-950 text-white shadow-sm"
    }`}
  >
    <div class="relative flex h-9 w-8 flex-col items-center justify-center leading-none sm:h-12 sm:w-10">
      <span class="font-serif text-[26px] font-light leading-[0.72] tracking-[-0.08em] sm:text-[34px]">
        M
      </span>

      <span class="-mt-1 font-serif text-[26px] font-light leading-[0.72] tracking-[-0.08em] sm:text-[34px]">
        M
      </span>
    </div>
  </div>

  <div class="min-w-0 overflow-hidden">
    <p
      class={`truncate font-serif text-[1.45rem] font-light tracking-[0.12em] transition sm:text-[2.15rem] sm:tracking-[0.22em] ${
        isLight ? "text-white" : "text-zinc-950 group-hover:text-zinc-700"
      }`}
    >
      MUSKELMÄNNER
    </p>

    <div class="mt-1.5 flex min-w-0 items-center gap-2 sm:mt-2 sm:gap-4">
      <div
        class={`h-px w-7 shrink-0 sm:w-12 ${
          isLight ? "bg-zinc-500" : "bg-zinc-300"
        }`}
      ></div>

      <p
        class={`truncate text-[9px] uppercase tracking-[0.22em] sm:text-[11px] sm:tracking-[0.38em] ${
          isLight ? "text-zinc-400" : "text-zinc-500"
        }`}
      >
        Entrümpelung Berlin
      </p>
    </div>
  </div>
</a>