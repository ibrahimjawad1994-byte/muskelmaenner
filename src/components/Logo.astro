---
const { variant = "default" } = Astro.props;
const isLight = variant === "light";
---

<a href="/" class="group flex min-w-0 items-center gap-3">
  <div
    class={`flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl transition sm:h-14 sm:w-14 ${
      isLight ? "bg-white text-zinc-950" : "bg-zinc-950 text-white"
    }`}
  >
    <div class="flex flex-col items-center justify-center leading-none">
      <span class="font-serif text-[27px] font-light leading-[0.72] tracking-[-0.08em]">
        M
      </span>
      <span class="-mt-1 font-serif text-[27px] font-light leading-[0.72] tracking-[-0.08em]">
        M
      </span>
    </div>
  </div>

  <div class="min-w-0">
    <p
      class={`truncate font-serif text-[1.65rem] font-light tracking-[0.18em] sm:text-[2rem] ${
        isLight ? "text-white" : "text-zinc-950"
      }`}
    >
      MUSKELMÄNNER
    </p>

    <div class="mt-1.5 flex min-w-0 items-center gap-3">
      <div class={`h-px w-9 shrink-0 ${isLight ? "bg-zinc-500" : "bg-zinc-300"}`}></div>

      <p
        class={`truncate text-[9px] uppercase tracking-[0.28em] sm:text-[10px] ${
          isLight ? "text-zinc-400" : "text-zinc-500"
        }`}
      >
        Entrümpelung Berlin
      </p>
    </div>
  </div>
</a>