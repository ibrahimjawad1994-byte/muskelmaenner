---
import { company } from "../config/company";
import Logo from "./Logo.astro";

const currentYear = new Date().getFullYear();

const services = [
  {
    label: "Wohnungsentrümpelung",
    href: "/services/wohnungsentruempelung-berlin",
  },
  {
    label: "Haushaltsauflösung",
    href: "/services/haushaltsaufloesung-berlin",
  },
  {
    label: "Kellerentrümpelung",
    href: "/services/keller-entruempelung-berlin",
  },
  {
    label: "Büroentrümpelung",
    href: "/services/buero-entruempelung-berlin",
  },
];
---

<footer class="relative overflow-hidden border-t border-zinc-200 bg-zinc-950 text-white">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute left-0 top-0 h-full w-full bg-[radial-gradient(circle_at_top_left,white,transparent_35%)]"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="grid gap-10 lg:grid-cols-[1.4fr_0.8fr_0.8fr_0.8fr] lg:gap-14">
      <div class="min-w-0">
        <Logo variant="light" />

        <p class="mt-6 max-w-md text-sm leading-7 text-zinc-400 sm:mt-8 sm:text-base sm:leading-8">
          Professionelle Entrümpelungen, Haushaltsauflösungen und Räumungen
          für private und gewerbliche Kunden in Berlin und Umgebung.
        </p>

        <div class="mt-7 grid gap-3 sm:mt-8 sm:flex sm:flex-wrap">
          <a
            href="/kontakt"
            class="rounded-2xl bg-white px-6 py-3 text-center text-sm font-medium text-zinc-950 transition hover:bg-zinc-100"
          >
            Angebot anfragen
          </a>

          <a
            href={`tel:${company.phoneTel}`}
            class="rounded-2xl border border-white/15 px-6 py-3 text-center text-sm font-medium text-white transition hover:bg-white/10"
          >
            Anrufen
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500 sm:tracking-[0.24em]">
          Navigation
        </h3>

        <ul class="mt-5 grid gap-3 text-sm sm:mt-6 sm:gap-4 sm:text-base">
          <li>
            <a href="/" class="text-zinc-400 transition hover:text-white">
              Startseite
            </a>
          </li>

          <li>
            <a href="/leistungen" class="text-zinc-400 transition hover:text-white">
              Leistungen
            </a>
          </li>

          <li>
            <a href="/preise" class="text-zinc-400 transition hover:text-white">
              Preise
            </a>
          </li>

          <li>
            <a href="/kontakt" class="text-zinc-400 transition hover:text-white">
              Kontakt
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500 sm:tracking-[0.24em]">
          Leistungen
        </h3>

        <ul class="mt-5 grid gap-3 text-sm sm:mt-6 sm:gap-4 sm:text-base">
          {
            services.map((service) => (
              <li>
                <a
                  href={service.href}
                  class="text-zinc-400 transition hover:text-white"
                >
                  {service.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500 sm:tracking-[0.24em]">
          Kontakt
        </h3>

        <ul class="mt-5 grid gap-3 text-sm sm:mt-6 sm:gap-4 sm:text-base">
          <li>
            <a
              href={`tel:${company.phoneTel}`}
              class="break-words text-zinc-400 transition hover:text-white"
            >
              {company.phoneDisplay}
            </a>
          </li>

          <li>
            <a
              href={`mailto:${company.email}`}
              class="break-all text-zinc-400 transition hover:text-white"
            >
              {company.email}
            </a>
          </li>

          <li class="text-zinc-400">
            {company.serviceArea}
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-6 sm:mt-16 sm:pt-8">
      <div class="flex flex-col gap-4 text-sm text-zinc-500 sm:flex-row sm:items-center sm:justify-between">
        <p class="leading-6">
          © {currentYear} Muskelmänner. Alle Rechte vorbehalten.
        </p>

        <div class="flex flex-wrap items-center gap-5 sm:gap-6">
          <a href="/impressum" class="transition hover:text-white">
            Impressum
          </a>

          <a href="/datenschutz" class="transition hover:text-white">
            Datenschutz
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>